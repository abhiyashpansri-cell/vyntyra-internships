NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/vyntyra-internships
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://internships.vyntyraconsultancyservices.in,https://vyntyraconsultancyservices.in,https://www.vyntyraconsultancyservices.in
ALLOW_NETLIFY_PREVIEWS=true
FRONTEND_BASE_URL=https://internships.vyntyraconsultancyservices.in
BACKEND_BASE_URL=https://vyntyrainternships-backend.onrender.com
PAYMENT_SUCCESS_URL=https://internships.vyntyraconsultancyservices.in/?payment=success
PAYMENT_FAILURE_URL=https://internships.vyntyraconsultancyservices.in/?payment=failure
UPLOAD_DIR=uploads
RESUME_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/1gXX1KCWYaRB9ra0UBtk9I4CBcjTPb9EP

# Production API routing:
# If backend is on separate domain, set data-backend-host in index.html body
# Example: data-backend-host="api.internships.vyntyraconsultancyservices.in" 
# (will try https://api.internships.vyntyraconsultancyservices.in/api)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxx
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=

# Zoho SMTP (recommended for automated email)
ZOHO_EMAIL=internships@vyntyraconsultancyservices.in
ZOHO_APP_PASSWORD=
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_SECURE=true


# RabbitMQ
RABBITMQ_URL=amqp://127.0.0.1:5672
RABBITMQ_EXCHANGE=vyntyra.jobs
RABBITMQ_QUEUE=vyntyra.jobs.queue
RABBITMQ_PREFETCH=20
RABBITMQ_CONNECT_TIMEOUT_MS=2500
RABBITMQ_CIRCUIT_OPEN_MS=30000

# Latency observability
ENABLE_REQUEST_TIMING_LOGS=true
REQUEST_TIMING_SAMPLE_RATE=1

# DB reconnect tuning
MONGODB_RETRY_DELAY_MS=5000

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=vyntyra-applications

# Optional
COMPANY_LOGO_URL=https://vyntyraconsultancyservices.in/assets/media/logo.png

# SMTP
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=internships@vyntyraconsultancyservices.in
