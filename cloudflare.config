# Cloudflare deployment hints
# Keeps headers and caching aligned with the security posture requested.
origin = "https://vyntyraconsultancyservices.in"
ssl = "full"
hsts = "max-age=63072000; includeSubDomains; preload"
waf = "managed"  # keep top-rated rules active for internship intake forms
cache_level = "aggressive"
bypass_cache_on_cookie = "__cf_bm"
security_level = "high"
under_attack = false
browser_check = true
